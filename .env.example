# App Settings
PROJECT_NAME="NexusBI Backend"
ENV=development
DEBUG=true

# Security Settings
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=placeholder_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL Metadata Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexusbi_metadata

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Snowflake Analytics DW Settings
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# AI Model API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
