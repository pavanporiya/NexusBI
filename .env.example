# ═══════════════════════════════════════════════════════════════════════════
# NexusBI Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for your environment.
# See config/envs/ for environment-specific overrides.

# ── Application ───────────────────────────────────────────────────────────
PROJECT_NAME="NexusBI Backend"
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
VERSION=1.0.0

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Security ──────────────────────────────────────────────────────────────
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=placeholder_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=RS256

# ── PostgreSQL Metadata Database ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexusbi_metadata
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Snowflake Analytics DW ────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
SNOWFLAKE_QUERY_TIMEOUT=30

# ── AI Model Configuration ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=gpt-4o
LLM_REQUEST_TIMEOUT=15
LLM_MAX_RETRIES=2

# ── Feature Flags ─────────────────────────────────────────────────────────
ENABLE_SEMANTIC_CACHE=false
ENABLE_FORECASTING=true
ENABLE_AUDIT_LOGGING=true

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CHAT_MESSAGES_PER_MINUTE=30

# ── Query Guardrails ──────────────────────────────────────────────────────
MAX_QUERY_ROW_LIMIT=50000
MAX_QUERY_TEXT_LENGTH=2000

# ── Observability ─────────────────────────────────────────────────────────
ENABLE_REQUEST_LOGGING=true
ENABLE_METRICS=false
