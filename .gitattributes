# Set default behavior to automatic text conversion.
* text=auto

# Force LF line endings for python, javascript, shell scripts, and configs.
*.py text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.mako text eol=lf
*.csv text eol=lf
*.sql text eol=lf
*.config text eol=lf

# Denote binary files to prevent text line conversion.
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
