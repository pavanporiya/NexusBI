# App Settings
PROJECT_NAME="NexusBI Backend Staging"
ENV=staging
DEBUG=false

# Security Settings
# Will be injected at deployment runtime via secret manager
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL Metadata Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=nexusbi_metadata

# Redis Settings
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0

# Snowflake Analytics DW Settings
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# AI Model API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
