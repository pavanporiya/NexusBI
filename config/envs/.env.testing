# App Settings
PROJECT_NAME="NexusBI Backend Testing"
ENV=testing
DEBUG=true

# Security Settings
SECRET_KEY=testing_secret_key_value
ACCESS_TOKEN_EXPIRE_MINUTES=5

# PostgreSQL Metadata Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexusbi_testing

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# Snowflake Mock Settings
SNOWFLAKE_ACCOUNT=mock_account
SNOWFLAKE_USER=mock_user
SNOWFLAKE_PASSWORD=mock_password
SNOWFLAKE_DATABASE=mock_database
SNOWFLAKE_SCHEMA=mock_schema
SNOWFLAKE_WAREHOUSE=mock_warehouse
SNOWFLAKE_ROLE=mock_role

# AI Model Mock API Keys
ANTHROPIC_API_KEY=mock_anthropic_key
OPENAI_API_KEY=mock_openai_key
